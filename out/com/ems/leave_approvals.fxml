<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.ems.LeaveApprovalController"
            styleClass="root-pane"
            stylesheets="@styles.css"
            prefWidth="1200" prefHeight="780">

    <left>
        <VBox styleClass="app-sidebar" prefWidth="234" BorderPane.alignment="CENTER">
            <VBox spacing="2">
                <Label text="EMS" styleClass="sidebar-logo"/>
                <Label text="People operations hub" styleClass="sidebar-subtitle"/>
            </VBox>

            <VBox styleClass="sidebar-section" VBox.vgrow="ALWAYS">
                <Label text="WORKSPACE" styleClass="side-section-label"/>
                <Button fx:id="dashboardNavButton" text="⊞  Dashboard" styleClass="side-nav-button"
                        maxWidth="Infinity" onAction="#goToDashboard"/>
                <Button fx:id="employeeAddNavButton" text="＋  Employee Add" styleClass="side-nav-button"
                        maxWidth="Infinity" onAction="#goToAdd"/>
                <Button fx:id="employeeDeactivateNavButton" text="⊗  Deactivate" styleClass="side-nav-button"
                        maxWidth="Infinity" onAction="#goToDeactivate"/>
                <Button fx:id="departmentNavButton" text="⊠  Departments" styleClass="side-nav-button"
                        maxWidth="Infinity" onAction="#goToDepartments"/>
                <Button fx:id="employeeSearchNavButton" text="⊛  Employee Search" styleClass="side-nav-button"
                        maxWidth="Infinity" onAction="#goToEmployeeSearch"/>
                <Button fx:id="attendanceNavButton" text="◉  Attendance" styleClass="side-nav-button"
                        maxWidth="Infinity" onAction="#goToAttendance"/>
                <Button fx:id="leaveApplyNavButton" text="◫  Leave Requests" styleClass="side-nav-button"
                        maxWidth="Infinity" onAction="#goToLeaveApply"/>
                <Button fx:id="leaveApprovalsNavButton" text="✔  Leave Approvals" styleClass="side-nav-active"
                        maxWidth="Infinity" onAction="#goToLeaveApprovals"/>
                <Button fx:id="payrollNavButton" text="◈  Payroll" styleClass="side-nav-button"
                        maxWidth="Infinity" onAction="#goToPayroll"/>
                <Button fx:id="documentsNavButton" text="◻  Documents" styleClass="side-nav-button"
                        maxWidth="Infinity" onAction="#goToDocuments"/>

                <Label text="ACCOUNT" styleClass="side-section-label"/>
                <Button text="⊘  Log Out" styleClass="side-nav-button"
                        maxWidth="Infinity" onAction="#handleLogout"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Signed in as" styleClass="sidebar-footnote"/>
                <Label fx:id="userLabel" styleClass="sidebar-user-chip" maxWidth="Infinity"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <BorderPane styleClass="workspace-shell">
            <top>
                <HBox styleClass="app-topbar" alignment="CENTER_LEFT" spacing="14">
                    <VBox spacing="0">
                        <Label text="✔  Leave Approvals" styleClass="topbar-title"/>
                        <Label text="Review pending requests and publish final decisions" styleClass="topbar-subtitle"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
<Label text="Approver" styleClass="topbar-pill"/>
                </HBox>
            </top>

            <center>
                <ScrollPane fitToWidth="true" fitToHeight="true" styleClass="content-scroll">
                    <content>
                        <VBox styleClass="content-body" spacing="16">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label text="Pending Leave Requests" styleClass="page-title"/>
                                <Label text="REVIEW" styleClass="badge-pill"/>
                            </HBox>

                            <VBox styleClass="summary-strip" spacing="4">
                                <Label fx:id="selectedRequestLabel" styleClass="summary-label" wrapText="true"/>
                            </VBox>

                            <VBox styleClass="section-card" spacing="0">
                                <TableView fx:id="pendingTable" prefHeight="295">
                                    <columns>
                                        <TableColumn fx:id="pendingIdColumn" text="ID" prefWidth="65"/>
                                        <TableColumn fx:id="pendingEmployeeColumn" text="Employee" prefWidth="270"/>
                                        <TableColumn fx:id="pendingTypeColumn" text="Type" prefWidth="150"/>
                                        <TableColumn fx:id="pendingDaysColumn" text="Days" prefWidth="90"/>
                                        <TableColumn fx:id="pendingDatesColumn" text="Dates" prefWidth="300"/>
                                    </columns>
                                </TableView>

                                <Label text="Decision Comments" styleClass="field-label"/>
                                <TextArea fx:id="commentsArea"
                                          styleClass="input-area"
                                          promptText="Optional comments for approval or rejection"/>

                                <HBox spacing="10" maxWidth="Infinity">
                                    <Button text="Approve Selected" styleClass="btn-gold"
                                            HBox.hgrow="ALWAYS" maxWidth="Infinity" onAction="#handleApprove"/>
                                    <Button text="Reject Selected" styleClass="btn-red"
                                            HBox.hgrow="ALWAYS" maxWidth="Infinity" onAction="#handleReject"/>
                                    <Button text="Refresh" styleClass="btn-neutral"
                                            HBox.hgrow="ALWAYS" maxWidth="Infinity" onAction="#handleRefresh"/>
                                </HBox>

                                <Label fx:id="statusLabel" styleClass="status-label" wrapText="true" maxWidth="Infinity"/>
                            </VBox>

                            <VBox styleClass="section-card" spacing="0">
                                <Label text="Decision History" styleClass="section-title"/>
                                <TableView fx:id="historyTable" prefHeight="250">
                                    <columns>
                                        <TableColumn fx:id="historyIdColumn" text="ID" prefWidth="65"/>
                                        <TableColumn fx:id="historyEmployeeColumn" text="Employee" prefWidth="320"/>
                                        <TableColumn fx:id="historyStatusColumn" text="Status" prefWidth="140"/>
                                        <TableColumn fx:id="historyDecisionByColumn" text="Decision By" prefWidth="180"/>
                                    </columns>
                                </TableView>
                            </VBox>
                        </VBox>
                    </content>
                </ScrollPane>
            </center>
        </BorderPane>
    </center>
</BorderPane>