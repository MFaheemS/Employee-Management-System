<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.ems.AttendanceController"
      styleClass="root-pane"
      stylesheets="@styles.css"
      prefWidth="860" prefHeight="680"
      spacing="0">

    <HBox styleClass="nav-bar" alignment="CENTER_LEFT" spacing="0">
        <Label text="EMS" styleClass="nav-title"/>
        <Region HBox.hgrow="ALWAYS" minWidth="20"/>
        <Label fx:id="userLabel" styleClass="nav-user"/>
        <Button fx:id="employeeAddNavButton" text="Employee Add" styleClass="nav-btn" onAction="#goToAdd"/>
        <Button fx:id="employeeDeactivateNavButton" text="Employee Deactivate" styleClass="nav-btn" onAction="#goToDeactivate"/>
        <Button text="Apply Leave" styleClass="nav-btn" onAction="#goToLeaveApply"/>
        <Button text="Attendance" styleClass="nav-btn-active" onAction="#goToAttendance"/>
        <Button fx:id="leaveApprovalsNavButton" text="Leave Approvals" styleClass="nav-btn" onAction="#goToLeaveApprovals"/>
        <Button fx:id="employeeSearchNavButton" text="Employee Search" styleClass="nav-btn" onAction="#goToEmployeeSearch"/>
        <Button text="Logout" styleClass="nav-btn" onAction="#handleLogout"/>
    </HBox>

    <StackPane VBox.vgrow="ALWAYS">
        <VBox styleClass="wide-card" maxWidth="760" spacing="0" StackPane.alignment="CENTER">
            <Label text="Attendance Management" styleClass="card-title" maxWidth="Infinity" alignment="CENTER"/>

            <Label fx:id="employeeSummaryLabel" styleClass="summary-label" wrapText="true"/>
            <Label fx:id="todayStatusLabel" styleClass="summary-highlight"/>
            <Label fx:id="todayCheckInLabel" styleClass="summary-label"/>
            <Label fx:id="todayCheckOutLabel" styleClass="summary-label"/>
            <Label fx:id="todayHoursLabel" styleClass="summary-label"/>

            <Region prefHeight="8"/>

            <Button text="Mark Attendance (Check-in / Check-out)" styleClass="btn-gold"
                    maxWidth="Infinity" onAction="#handleMarkAttendance"/>

            <Label fx:id="actionStatusLabel" styleClass="status-label" wrapText="true" maxWidth="Infinity"/>

            <Separator styleClass="section-separator"/>

            <Label text="Recent Attendance" styleClass="section-title"/>
            <TableView fx:id="historyTable" prefHeight="260">
                <columns>
                    <TableColumn fx:id="historyDateColumn" text="Date" prefWidth="170"/>
                    <TableColumn fx:id="historyCheckInColumn" text="Check-in" prefWidth="210"/>
                    <TableColumn fx:id="historyCheckOutColumn" text="Check-out" prefWidth="210"/>
                    <TableColumn fx:id="historyHoursColumn" text="Total Hours" prefWidth="130"/>
                </columns>
            </TableView>
        </VBox>
    </StackPane>
</VBox>