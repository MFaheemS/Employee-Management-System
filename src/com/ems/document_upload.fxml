<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.ems.DocumentController"
      styleClass="root-pane"
      stylesheets="@styles.css"
      prefWidth="1200" prefHeight="780">

  <left>
    <VBox styleClass="app-sidebar" prefWidth="234" BorderPane.alignment="CENTER">
      <VBox spacing="3">
        <HBox alignment="CENTER_LEFT" spacing="8">
          <Label text="⬡" style="-fx-text-fill: #A78BFA; -fx-font-size: 22px;"/>
          <Label text="EMS" styleClass="sidebar-logo"/>
        </HBox>
        <Label text="People operations hub" styleClass="sidebar-subtitle"/>
      </VBox>

      <VBox styleClass="sidebar-section" VBox.vgrow="ALWAYS">
        <Label text="WORKSPACE" styleClass="side-section-label"/>
        <Button fx:id="dashboardNavButton" text="⊞  Dashboard" styleClass="side-nav-button"
            maxWidth="Infinity" onAction="#goToDashboard"/>
        <Button fx:id="employeeAddNavButton" text="＋  Employee Add" styleClass="side-nav-button"
            maxWidth="Infinity" onAction="#goToAdd"/>
        <Button fx:id="employeeDeactivateNavButton" text="⊗  Deactivate" styleClass="side-nav-button"
            maxWidth="Infinity" onAction="#goToDeactivate"/>
        <Button fx:id="departmentNavButton" text="⊠  Departments" styleClass="side-nav-button"
            maxWidth="Infinity" onAction="#goToDepartments"/>
        <Button fx:id="employeeSearchNavButton" text="⊛  Employee Search" styleClass="side-nav-button"
            maxWidth="Infinity" onAction="#goToEmployeeSearch"/>
        <Button fx:id="attendanceNavButton" text="◉  Attendance" styleClass="side-nav-button"
            maxWidth="Infinity" onAction="#goToAttendance"/>
        <Button fx:id="leaveApplyNavButton" text="◫  Leave Requests" styleClass="side-nav-button"
            maxWidth="Infinity" onAction="#goToLeaveApply"/>
        <Button fx:id="leaveApprovalsNavButton" text="✔  Leave Approvals" styleClass="side-nav-button"
            maxWidth="Infinity" onAction="#goToLeaveApprovals"/>
        <Button fx:id="payrollNavButton" text="◈  Payroll" styleClass="side-nav-button"
            maxWidth="Infinity" onAction="#goToPayroll"/>
        <Button fx:id="documentsNavButton" text="◻  Documents" styleClass="side-nav-active"
            maxWidth="Infinity" onAction="#goToDocuments"/>

        <Label text="ACCOUNT" styleClass="side-section-label"/>
        <Button text="⊘  Log Out" styleClass="side-nav-button"
            maxWidth="Infinity" onAction="#handleLogout"/>
      </VBox>

      <VBox spacing="5">
        <Label text="Signed in as" styleClass="sidebar-footnote"/>
        <Label fx:id="userLabel" styleClass="sidebar-user-chip" maxWidth="Infinity"/>
      </VBox>
    </VBox>
  </left>

  <center>
    <BorderPane styleClass="workspace-shell">
      <top>
        <HBox styleClass="app-topbar" alignment="CENTER_LEFT" spacing="14">
          <VBox spacing="0">
            <Label text="Document Centre" styleClass="topbar-title"/>
            <Label text="Employee document storage, uploads and management" styleClass="topbar-subtitle"/>
          </VBox>
          <Region HBox.hgrow="ALWAYS"/>
          <Label text="◻ Docs" styleClass="topbar-pill"/>
        </HBox>
      </top>

      <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" styleClass="content-scroll">
          <content>
            <VBox styleClass="content-body" spacing="20">

              <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Documents" styleClass="page-title"/>
                <Label text="ACTIVE MODULE" styleClass="badge-pill"/>
              </HBox>

              <!-- Role info banner -->
              <VBox styleClass="summary-strip">
                <Label fx:id="roleInfoLabel" styleClass="summary-label" wrapText="true"/>
              </VBox>

              <!-- ═══ UPLOAD SECTION — Employee only ═══ -->
              <VBox fx:id="uploadSection" styleClass="section-card" spacing="0">
                <Label text="📎  Upload Your Document" styleClass="card-title"/>
                <Label text="Supported: PDF, PNG, JPG, JPEG, DOC, DOCX, TXT. Max one file at a time."
                       styleClass="page-subtitle"/>

                <Label text="Select File" styleClass="field-label"/>
                <HBox spacing="10" alignment="CENTER_LEFT" maxWidth="Infinity">
                  <TextField fx:id="filePathField" styleClass="input-field"
                         promptText="No file selected" HBox.hgrow="ALWAYS"
                         editable="false" maxWidth="Infinity"/>
                  <Button text="Browse..." styleClass="btn-neutral" onAction="#handleBrowse"/>
                </HBox>

                <Region prefHeight="12"/>
                <HBox spacing="10">
                  <Button text="Upload Document" styleClass="btn-gold" onAction="#handleUpload"/>
                </HBox>
                <Label fx:id="uploadStatusLabel" styleClass="status-label" wrapText="true"/>
              </VBox>

              <!-- ═══ VIEW / MANAGE SECTION ═══ -->
              <VBox styleClass="section-card" spacing="0">
                <HBox alignment="CENTER_LEFT" spacing="10">
                  <Label text="📁  Document Records" styleClass="card-title" HBox.hgrow="ALWAYS"/>

                  <!-- Filter bar — Admin/Manager only -->
                  <VBox fx:id="filterSection" spacing="0">
                    <HBox spacing="8" alignment="CENTER_LEFT">
                      <TextField fx:id="filterField" styleClass="input-field"
                             promptText="Filter by Employee ID..." prefWidth="220"/>
                      <Button text="Filter" styleClass="btn-neutral" onAction="#handleFilter"/>
                      <Button text="Show All" styleClass="btn-neutral" onAction="#handleShowAll"/>
                    </HBox>
                  </VBox>
                </HBox>

                <TableView fx:id="documentsTable" prefHeight="320">
                  <columns>
                    <TableColumn fx:id="colEmpId" text="Employee ID" prefWidth="110"/>
                    <TableColumn fx:id="colFileName" text="File Name" prefWidth="210"/>
                    <TableColumn fx:id="colFileType" text="Type" prefWidth="60"/>
                    <TableColumn fx:id="colUploadedAt" text="Uploaded At" prefWidth="150"/>
                    <TableColumn fx:id="colUploadedBy" text="Uploaded By" prefWidth="110"/>
                    <TableColumn fx:id="colStatus" text="Status" prefWidth="90"/>
                  </columns>
                </TableView>

                <Region prefHeight="10"/>

                <!-- Manager actions: Approve / Reject / Delete -->
                <VBox fx:id="managerActionsSection" spacing="8">
                  <HBox spacing="10">
                    <Button fx:id="approveDocButton" text="✔  Approve"
                        styleClass="btn-gold" onAction="#handleApproveDocument"/>
                    <Button fx:id="rejectDocButton" text="✖  Reject"
                        styleClass="btn-neutral" onAction="#handleRejectDocument"/>
                    <Button fx:id="deleteDocButton" text="🗑  Delete"
                        styleClass="btn-red" onAction="#handleDeleteDocument"/>
                  </HBox>
                </VBox>

                <!-- Employee action: Open file -->
                <VBox fx:id="employeeActionsSection" spacing="8">
                  <HBox spacing="10">
                    <Button fx:id="openFileButton" text="📂  Open Selected File"
                        styleClass="btn-neutral" onAction="#handleOpenFile"/>
                  </HBox>
                </VBox>

              </VBox>

            </VBox>
          </content>
        </ScrollPane>
      </center>
    </BorderPane>
  </center>
</BorderPane>
