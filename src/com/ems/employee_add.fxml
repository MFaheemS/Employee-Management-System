<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.ems.EmployeeAddController"
      styleClass="root-pane"
      stylesheets="@styles.css"
      prefWidth="520" prefHeight="620"
      spacing="0">

    <!-- Navigation Bar -->
    <HBox styleClass="nav-bar" alignment="CENTER_LEFT" spacing="0">
        <Label text="EMS" styleClass="nav-title"/>
        <Region HBox.hgrow="ALWAYS" minWidth="20"/>
      <Label fx:id="userLabel" styleClass="nav-user"/>
      <Button fx:id="employeeAddNavButton" text="Employee Add" styleClass="nav-btn-active"
                onAction="#goToAdd"/>
      <Button fx:id="employeeDeactivateNavButton" text="Employee Deactivate" styleClass="nav-btn"
                onAction="#goToDeactivate"/>
      <Button text="Apply Leave" styleClass="nav-btn"
        fx:id="leaveApplyNavButton" onAction="#goToLeaveApply"/>
      <Button text="Attendance" styleClass="nav-btn"
        fx:id="attendanceNavButton" onAction="#goToAttendance"/>
      <Button text="Leave Approvals" styleClass="nav-btn"
        fx:id="leaveApprovalsNavButton" onAction="#goToLeaveApprovals"/>
      <Button text="Employee Search" styleClass="nav-btn"
        fx:id="employeeSearchNavButton" onAction="#goToEmployeeSearch"/>
      <Button text="Logout" styleClass="nav-btn"
        onAction="#handleLogout"/>
    </HBox>

    <!-- Card -->
    <StackPane VBox.vgrow="ALWAYS">
        <VBox styleClass="card" maxWidth="400" spacing="0"
              StackPane.alignment="CENTER">

            <Label text="Employee Add" styleClass="card-title"
                   maxWidth="Infinity" alignment="CENTER"/>

            <Label text="Employee ID" styleClass="field-label"/>
            <TextField fx:id="employeeIdField" styleClass="input-field"
                       maxWidth="Infinity"/>

            <Label text="Full Name" styleClass="field-label"/>
            <TextField fx:id="fullNameField" styleClass="input-field"
                       maxWidth="Infinity"/>

            <Label text="Job Title" styleClass="field-label"/>
            <TextField fx:id="jobTitleField" styleClass="input-field"
                       maxWidth="Infinity"/>

            <Label text="Department" styleClass="field-label"/>
            <TextField fx:id="departmentField" styleClass="input-field"
                       maxWidth="Infinity"/>

            <Label text="Email" styleClass="field-label"/>
            <TextField fx:id="emailField" styleClass="input-field"
                       maxWidth="Infinity"/>

            <Region prefHeight="18"/>

                <HBox spacing="10" maxWidth="Infinity">
              <Button text="Add Employee" styleClass="btn-gold"
                maxWidth="Infinity" HBox.hgrow="ALWAYS"
                onAction="#handleAddEmployee"/>
              <Button text="Find by ID" styleClass="btn-neutral"
                maxWidth="Infinity" HBox.hgrow="ALWAYS"
                onAction="#handleFindEmployee"/>
                </HBox>

                <Region prefHeight="10"/>

                <HBox spacing="10" maxWidth="Infinity">
              <Button text="Update Employee" styleClass="btn-neutral"
                maxWidth="Infinity" HBox.hgrow="ALWAYS"
                onAction="#handleUpdateEmployee"/>
              <Button text="Delete Employee" styleClass="btn-red"
                maxWidth="Infinity" HBox.hgrow="ALWAYS"
                onAction="#handleDeleteEmployee"/>
                </HBox>

        </VBox>
    </StackPane>

</VBox>
