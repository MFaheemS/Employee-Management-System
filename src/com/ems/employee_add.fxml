<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.ems.EmployeeAddController"
      styleClass="root-pane"
      stylesheets="@styles.css"
      prefWidth="1200" prefHeight="780">

  <left>
    <VBox styleClass="app-sidebar" prefWidth="234" BorderPane.alignment="CENTER">
      <VBox spacing="3">
        <HBox alignment="CENTER_LEFT" spacing="8">
          <Label text="⬡" style="-fx-text-fill: #A78BFA; -fx-font-size: 22px;"/>
          <Label text="EMS" styleClass="sidebar-logo"/>
        </HBox>
        <Label text="People operations hub" styleClass="sidebar-subtitle"/>
      </VBox>

      <VBox styleClass="sidebar-section" VBox.vgrow="ALWAYS">
        <Label text="WORKSPACE" styleClass="side-section-label"/>
        <Button fx:id="dashboardNavButton" text="⊞  Dashboard" styleClass="side-nav-button"
            maxWidth="Infinity" onAction="#goToDashboard"/>
        <Button fx:id="employeeAddNavButton" text="＋  Employee Add" styleClass="side-nav-active"
            maxWidth="Infinity" onAction="#goToAdd"/>
        <Button fx:id="employeeDeactivateNavButton" text="⊗  Deactivate" styleClass="side-nav-button"
            maxWidth="Infinity" onAction="#goToDeactivate"/>
        <Button fx:id="departmentNavButton" text="⊠  Departments" styleClass="side-nav-button"
            maxWidth="Infinity" onAction="#goToDepartments"/>
        <Button fx:id="employeeSearchNavButton" text="⊛  Employee Search" styleClass="side-nav-button"
            maxWidth="Infinity" onAction="#goToEmployeeSearch"/>
        <Button fx:id="attendanceNavButton" text="◉  Attendance" styleClass="side-nav-button"
            maxWidth="Infinity" onAction="#goToAttendance"/>
        <Button fx:id="leaveApplyNavButton" text="◫  Leave Requests" styleClass="side-nav-button"
            maxWidth="Infinity" onAction="#goToLeaveApply"/>
        <Button fx:id="leaveApprovalsNavButton" text="✔  Leave Approvals" styleClass="side-nav-button"
            maxWidth="Infinity" onAction="#goToLeaveApprovals"/>
        <Button fx:id="payrollNavButton" text="◈  Payroll" styleClass="side-nav-button"
            maxWidth="Infinity" onAction="#goToPayroll"/>
        <Button fx:id="documentsNavButton" text="◻  Documents" styleClass="side-nav-button"
            maxWidth="Infinity" onAction="#goToDocuments"/>

        <Label text="ACCOUNT" styleClass="side-section-label"/>
        <Button text="⊘  Log Out" styleClass="side-nav-button"
            maxWidth="Infinity" onAction="#handleLogout"/>
      </VBox>

      <VBox spacing="5">
        <Label text="Signed in as" styleClass="sidebar-footnote"/>
        <Label fx:id="userLabel" styleClass="sidebar-user-chip" maxWidth="Infinity"/>
      </VBox>
    </VBox>
  </left>

  <center>
    <BorderPane styleClass="workspace-shell">
      <top>
        <HBox styleClass="app-topbar" alignment="CENTER_LEFT" spacing="14">
          <VBox spacing="0">
            <Label fx:id="topbarTitleLabel" text="Employee Management" styleClass="topbar-title"/>
            <Label fx:id="topbarSubtitleLabel" text="Create, find, and maintain employee records" styleClass="topbar-subtitle"/>
          </VBox>
          <Region HBox.hgrow="ALWAYS"/>
          <Label text="Admin Tools" styleClass="topbar-pill"/>
        </HBox>
      </top>

      <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" styleClass="content-scroll">
          <content>
            <VBox styleClass="content-body" spacing="16">
              <HBox alignment="CENTER_LEFT" spacing="10">
                <Label fx:id="pageTitleLabel" text="Add / Edit" styleClass="page-title"/>
                <Label text="ACTIVE MODULE" styleClass="badge-pill"/>
              </HBox>
              <Label fx:id="pageSubtitleLabel"
                     text="Use ID to add new records or retrieve existing profiles for updates."
                     styleClass="page-subtitle"/>

              <VBox styleClass="section-card" spacing="0">
                <HBox alignment="CENTER_LEFT" spacing="8">
                  <Label fx:id="cardTitleLabel" text="Details" styleClass="card-title"/>
                </HBox>

                <VBox spacing="3">

                  <!-- Row 1: ID + Name — always visible -->
                  <HBox spacing="14">
                    <VBox HBox.hgrow="ALWAYS" maxWidth="Infinity">
                      <Label fx:id="idFieldLabel" text="Manager ID" styleClass="field-label"/>
                      <HBox spacing="6" alignment="CENTER_LEFT">
                        <TextField fx:id="employeeIdField" styleClass="input-field"
                               promptText="M001" HBox.hgrow="ALWAYS"/>
                        <Button fx:id="autoIdButton" text="Auto"
                                styleClass="btn-auto-id" onAction="#handleAutoId"/>
                      </HBox>
                      <Label fx:id="idHintLabel" styleClass="field-hint" wrapText="true"/>
                    </VBox>
                    <VBox HBox.hgrow="ALWAYS" maxWidth="Infinity">
                      <Label text="Full Name" styleClass="field-label"/>
                      <TextField fx:id="fullNameField" styleClass="input-field"
                             promptText="e.g. Alice Morgan" maxWidth="Infinity"/>
                    </VBox>
                  </HBox>

                  <!-- Row 2: Job Title + Department — hidden for admin -->
                  <HBox fx:id="titleDeptRow" spacing="14">
                    <VBox HBox.hgrow="ALWAYS" maxWidth="Infinity">
                      <Label text="Job Title" styleClass="field-label"/>
                      <TextField fx:id="jobTitleField" styleClass="input-field"
                             promptText="e.g. HR Specialist" maxWidth="Infinity"/>
                    </VBox>
                    <VBox HBox.hgrow="ALWAYS" maxWidth="Infinity">
                      <Label text="Department" styleClass="field-label"/>
                      <ComboBox fx:id="departmentComboBox" styleClass="input-field"
                             maxWidth="Infinity" promptText="Select department"/>
                    </VBox>
                  </HBox>

                  <!-- Row 3: Email + Phone — always visible -->
                  <HBox spacing="14">
                    <VBox HBox.hgrow="ALWAYS" maxWidth="Infinity">
                      <Label text="Email" styleClass="field-label"/>
                      <TextField fx:id="emailField" styleClass="input-field"
                             promptText="user@company.com" maxWidth="Infinity"/>
                    </VBox>
                    <VBox HBox.hgrow="ALWAYS" maxWidth="Infinity">
                      <Label text="Phone" styleClass="field-label"/>
                      <TextField fx:id="phoneField" styleClass="input-field"
                             promptText="+92-300-0000000" maxWidth="Infinity"/>
                    </VBox>
                  </HBox>

                  <!-- Row 4: Salary — hidden for admin (0 until dept assigned) -->
                  <HBox fx:id="salaryRow" spacing="14">
                    <VBox HBox.hgrow="ALWAYS" maxWidth="Infinity">
                      <Label text="Monthly Salary (PKR)" styleClass="field-label"/>
                      <TextField fx:id="salaryField" styleClass="input-field"
                             promptText="e.g. 75000" maxWidth="Infinity"/>
                    </VBox>
                    <!-- hidden role field kept for controller compatibility -->
                    <VBox fx:id="roleRow" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                      <Label text="Role" styleClass="field-label"/>
                      <ComboBox fx:id="roleComboBox" styleClass="input-field"
                             maxWidth="Infinity" promptText="Select role"/>
                    </VBox>
                  </HBox>

                  <!-- Row 5: Username + Password — always visible -->
                  <HBox spacing="14">
                    <VBox HBox.hgrow="ALWAYS" maxWidth="Infinity">
                      <Label text="Login Username" styleClass="field-label"/>
                      <TextField fx:id="usernameField" styleClass="input-field"
                             promptText="e.g. alice.m" maxWidth="Infinity"/>
                    </VBox>
                    <VBox HBox.hgrow="ALWAYS" maxWidth="Infinity">
                      <Label text="Password" styleClass="field-label"/>
                      <PasswordField fx:id="passwordField" styleClass="input-field"
                             promptText="Set login password" maxWidth="Infinity"/>
                    </VBox>
                  </HBox>

                </VBox>

                <Region prefHeight="18"/>

                <HBox spacing="10" maxWidth="Infinity">
                  <Button fx:id="saveButton" text="Save" styleClass="btn-gold"
                      maxWidth="Infinity" HBox.hgrow="ALWAYS"
                      onAction="#handleAddEmployee"/>
                  <Button text="Find by ID" styleClass="btn-neutral"
                      maxWidth="Infinity" HBox.hgrow="ALWAYS"
                      onAction="#handleFindEmployee"/>
                </HBox>

                <Region prefHeight="10"/>

                <HBox spacing="10" maxWidth="Infinity">
                  <Button fx:id="updateButton" text="Update" styleClass="btn-neutral"
                      maxWidth="Infinity" HBox.hgrow="ALWAYS"
                      onAction="#handleUpdateEmployee"/>
                  <Button fx:id="deleteButton" text="Delete" styleClass="btn-danger"
                      maxWidth="Infinity" HBox.hgrow="ALWAYS"
                      onAction="#handleDeleteEmployee"/>
                </HBox>
              </VBox>

              <!-- Info card shown for admin: explains auto-derive behaviour -->
              <VBox fx:id="adminInfoCard" styleClass="section-card" spacing="6">
                <HBox alignment="CENTER_LEFT" spacing="10">
                  <Label text="ℹ  How Manager Assignment Works" styleClass="card-title"/>
                  <Region HBox.hgrow="ALWAYS"/>
                  <Label text="INFO" styleClass="badge-pill"/>
                </HBox>
                <Label text="• Job title is set automatically when you assign this manager to a department (e.g. 'Engineering Manager')."
                       styleClass="page-subtitle" wrapText="true"/>
                <Label text="• Salary starts at PKR 0 until a department is assigned. Update it from Employee Search after assignment."
                       styleClass="page-subtitle" wrapText="true"/>
                <Label text="• To assign a department, go to Departments → Create Department and select this manager."
                       styleClass="page-subtitle" wrapText="true"/>
              </VBox>

            </VBox>
          </content>
        </ScrollPane>
      </center>
    </BorderPane>
  </center>
</BorderPane>
