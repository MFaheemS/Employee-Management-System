<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.ems.LoginController"
           styleClass="root-pane"
           stylesheets="@styles.css"
                 prefWidth="620" prefHeight="560">

       <Pane styleClass="login-pattern" maxWidth="Infinity" maxHeight="Infinity" mouseTransparent="true">
              <Region styleClass="leaf-blob" prefWidth="270" prefHeight="230"
                            translateX="-210" translateY="-165"/>
              <Region styleClass="leaf-blob" prefWidth="240" prefHeight="210"
                            translateX="235" translateY="180"/>
              <Region styleClass="leaf-blob-soft" prefWidth="180" prefHeight="155"
                            translateX="220" translateY="-170"/>
       </Pane>

       <VBox styleClass="login-card" maxWidth="430" spacing="0"
                StackPane.alignment="CENTER">

              <HBox alignment="CENTER" spacing="10">
                     <Label text="LF" styleClass="brand-icon"/>
                     <Label text="EMS" styleClass="brand-title"/>
              </HBox>

              <Label text="Your workforce, beautifully managed."
                        styleClass="brand-tagline"
                        maxWidth="Infinity" alignment="CENTER"/>

              <Region prefHeight="18"/>

              <Label text="Username / Email" styleClass="field-label"/>
              <TextField fx:id="usernameField"
                               styleClass="input-field"
                               maxWidth="Infinity"
                               promptText="Enter your username"/>

              <Label text="Password" styleClass="field-label"/>
              <HBox spacing="8" alignment="CENTER_LEFT" maxWidth="Infinity">
                     <StackPane HBox.hgrow="ALWAYS">
                            <PasswordField fx:id="passwordField"
                                                    styleClass="input-field"
                                                    maxWidth="Infinity"
                                                    promptText="Enter your password"/>
                            <TextField fx:id="passwordVisibleField"
                                             styleClass="input-field"
                                             maxWidth="Infinity"
                                             visible="false"
                                             managed="false"
                                             promptText="Enter your password"/>
                     </StackPane>
                     <Button fx:id="togglePasswordButton"
                                   text="Show"
                                   styleClass="btn-inline"
                                   onAction="#togglePasswordVisibility"/>
              </HBox>

              <Region prefHeight="22"/>

              <Button text="Login"
                            styleClass="btn-gold"
                            maxWidth="Infinity"
                            onAction="#handleSubmit"/>

              <HBox alignment="CENTER_RIGHT">
                     <Hyperlink text="Forgot Password?" styleClass="login-link"/>
              </HBox>

              <Label fx:id="hintLabel"
                        styleClass="hint-label"
                        wrapText="true"
                        maxWidth="Infinity"/>

       </VBox>
</StackPane>
